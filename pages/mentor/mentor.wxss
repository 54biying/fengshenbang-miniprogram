/* 导师页样式 */
.search-bar {
  padding: 20rpx;
  background: white;
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.mentor-list {
  padding: 0 20rpx;
}

.mentor-item {
  display: flex;
  background: white;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.mentor-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.mentor-info {
  flex: 1;
}

.mentor-name {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.rating {
  display: flex;
  align-items: center;
}

.star {
  color: #faad14;
  font-size: 24rpx;
  margin-right: 8rpx;
}

.score {
  font-size: 24rpx;
  color: #666;
}

.mentor-title {
  font-size: 26rpx;
  color: #1890ff;
  display: block;
  margin-bottom: 8rpx;
}

.mentor-exp {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.mentor-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.tag {
  background: #f0f0f0;
  color: #666;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.mentor-price {
  font-size: 32rpx;
  color: #f5222d;
  font-weight: bold;
  display: block;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
