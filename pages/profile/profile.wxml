<!-- 个人资料页 -->
<view class="container">
  <view class="profile-header" wx:if="{{userInfo}}">
    <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" />
    <text class="name">{{userInfo.name || '用户'}}</text>
    <view class="level-badge">Lv.{{userLevel}}</view>
  </view>

  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-num">{{userPoints}}</text>
      <text class="stat-label">积分</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.testCount || 0}}</text>
      <text class="stat-label">测试</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.matchCount || 0}}</text>
      <text class="stat-label">匹配</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.giftCount || 0}}</text>
      <text class="stat-label">拜师</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToPoints">
      <text class="menu-icon">💎</text>
      <text class="menu-title">积分明细</text>
      <text class="arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToMyGifts">
      <text class="menu-icon">🎁</text>
      <text class="menu-title">我的拜师礼</text>
      <text class="arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToReceivedGifts">
      <text class="menu-icon">📩</text>
      <text class="menu-title">收到的拜师礼</text>
      <text class="arrow">></text>
    </view>

    <view class="menu-item" bindtap="editProfile">
      <text class="menu-icon">✏️</text>
      <text class="menu-title">编辑资料</text>
      <text class="arrow">></text>
    </view>

    <view class="menu-item" bindtap="contactSupport">
      <text class="menu-icon">💬</text>
      <text class="menu-title">联系客服</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="logout-section">
    <button class="btn btn-secondary logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
