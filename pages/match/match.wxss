/* 匹配页样式 */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
  padding: 0 20rpx;
}

.match-list {
  padding: 0 20rpx;
}

.match-item {
  display: flex;
  align-items: center;
  background: white;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.user-level {
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.user-tags {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.match-degree {
  font-size: 24rpx;
  color: #52c41a;
  display: block;
}

.small-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  padding: 0;
  border-radius: 8rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  background: white;
  border-radius: 16rpx;
  margin: 0 20rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
}

.request-list {
  padding: 0 20rpx;
}

.request-item {
  display: flex;
  align-items: center;
  background: white;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.request-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.request-info {
  flex: 1;
}

.request-name {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.request-time {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.request-actions {
  display: flex;
  gap: 16rpx;
}

.mini-btn {
  width: 100rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  padding: 0;
  border-radius: 8rpx;
}
