/* pages/match/match.wxss */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #f0f7ff 0%, #f5f5f5 100%);
  min-height: 100vh;
}

/* 我的状态卡片 */
.my-status-card {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.3);
}

.status-left {
  display: flex;
  align-items: center;
}

.my-level-badge {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  margin-right: 24rpx;
}

.my-level-badge.tested {
  background: #fff566;
}

.level-icon {
  font-size: 40rpx;
  display: block;
}

.level-text {
  font-size: 24rpx;
  color: white;
  display: block;
  font-weight: bold;
  margin-top: 4rpx;
}

.my-level-badge.tested .level-text {
  color: #d46b08;
}

.my-info {
  display: flex;
  flex-direction: column;
}

.my-label {
  font-size: 32rpx;
  color: white;
  font-weight: bold;
}

.my-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.status-actions {
  display: flex;
}

.btn-sm {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: white;
  color: #1890ff;
  border: none;
}

.btn-sm.btn-primary {
  background: white;
  color: #1890ff;
}

.btn-sm.btn-secondary {
  background: rgba(255, 255, 255, 0.3);
  color: white;
}

/* 区域 */
.section {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.section-count {
  font-size: 26rpx;
  color: #999;
  background: #f5f5f5;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 匹配列表 */
.match-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.match-item {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  transition: all 0.3s;
}

.match-item:active {
  background: #f0f0f0;
}

.match-main {
  flex: 1;
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #e6f7ff;
}

.user-info {
  flex: 1;
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.level-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.level-tag.level-1, .level-tag.level-2 {
  background: #e6f7ff;
  color: #1890ff;
}

.level-tag.level-3 {
  background: #fff7e6;
  color: #faad14;
}

.level-tag.level-4 {
  background: #fff1f0;
  color: #fa541c;
}

.level-tag.level-5 {
  background: linear-gradient(135deg, #f5222d, #faad14);
  color: white;
}

.user-tags {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.match-info {
  display: flex;
  align-items: center;
}

.match-bar {
  flex: 1;
  height: 8rpx;
  background: #e8e8e8;
  border-radius: 4rpx;
  margin-right: 16rpx;
  max-width: 200rpx;
}

.match-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #95de64);
  border-radius: 4rpx;
}

.match-percent {
  font-size: 24rpx;
  color: #52c41a;
  font-weight: bold;
}

.btn-match {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  color: white;
  padding: 20rpx 32rpx;
  border-radius: 32rpx;
  margin-left: 24rpx;
  font-size: 26rpx;
  border: none;
}

.btn-icon {
  font-size: 32rpx;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 40rpx;
}

.empty-icon-box {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #e6f7ff, #f0f7ff);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.empty-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

/* 请求列表 */
.request-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.request-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.request-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #e6f7ff;
}

.request-info {
  flex: 1;
}

.request-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.request-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.request-actions {
  display: flex;
  gap: 16rpx;
}

.btn-xs {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.btn-xs.btn-primary {
  background: #1890ff;
  color: white;
}

.btn-xs.btn-secondary {
  background: #f5f5f5;
  color: #999;
}

/* 说明区域 */
.info-section {
  background: linear-gradient(135deg, #fffbe6, #fff1b8);
  border-radius: 20rpx;
  padding: 32rpx;
  border: 2rpx solid #ffe58f;
}

.info-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #d46b08;
  display: block;
  margin-bottom: 24rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-num {
  width: 40rpx;
  height: 40rpx;
  background: #d46b08;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.info-text {
  font-size: 28rpx;
  color: #595959;
  flex: 1;
}

/* 通用按钮 */
.btn {
  padding: 24rpx 48rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  color: white;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
}
