/* 登录页样式 */
.login-header {
  text-align: center;
  padding: 120rpx 0 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 32rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  color: #1890ff;
}

.slogan {
  font-size: 28rpx;
  color: #999;
  display: block;
}

.login-form {
  padding: 40rpx;
}

/* 登录方式切换tab */
.login-type-tabs {
  display: flex;
  margin-bottom: 40rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: white;
  color: #1890ff;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.input-group {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  background: white;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  border: 2rpx solid #e8e8e8;
  box-sizing: border-box;
}

.code-input-wrap {
  display: flex;
  gap: 16rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  width: 200rpx;
  height: 88rpx;
  background: white;
  border: 2rpx solid #1890ff;
  border-radius: 12rpx;
  color: #1890ff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.code-btn[disabled] {
  border-color: #d9d9d9;
  color: #999;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: #1890ff;
  color: white;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 40rpx;
  border: none;
}

.tips {
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #999;
}

.tips .link {
  color: #1890ff;
}
