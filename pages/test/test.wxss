/* pages/test/test.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 空闲状态 */
.test-intro {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.test-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.test-icon-text {
  font-size: 80rpx;
}

.test-intro .title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.test-intro .desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.feature-list {
  width: 100%;
  margin-bottom: 40rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  width: 40rpx;
  height: 40rpx;
  background: #52c41a;
  border-radius: 50%;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.feature-text {
  font-size: 28rpx;
  color: #333;
}

.btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin: 15rpx 0;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-secondary {
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.btn-disabled {
  background: #ccc;
  color: #fff;
}

.start-btn {
  width: 80%;
}

/* 测试中状态 */
.test-ongoing {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  min-height: calc(100vh - 40rpx);
  display: flex;
  flex-direction: column;
}

.progress-header {
  margin-bottom: 30rpx;
}

.progress-bar {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin-top: 10rpx;
}

.question-card {
  flex: 1;
  background: #f8f8f8;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.question-category {
  font-size: 24rpx;
  color: #667eea;
  background: #e8f4ff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.6;
  display: block;
  margin-bottom: 30rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  transition: all 0.3s;
}

.option-item.selected {
  background: #e8f4ff;
  border-color: #667eea;
}

.option-radio {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-item.selected .option-radio {
  border-color: #667eea;
}

.radio-inner {
  width: 24rpx;
  height: 24rpx;
  background: #667eea;
  border-radius: 50%;
}

.option-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.action-bar {
  display: flex;
  gap: 20rpx;
}

.action-bar .btn {
  flex: 1;
  margin: 0;
}

/* 测试结果 */
.test-result {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
}

.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.result-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.result-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.result-level {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  margin-bottom: 15rpx;
}

.result-score {
  font-size: 56rpx;
  color: #fff;
  font-weight: bold;
}

.result-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.result-actions .btn {
  flex: 1;
}

.history-section {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #eee;
}

.history-list {
  margin-top: 20rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-info {
  display: flex;
  flex-direction: column;
}

.history-level {
  font-size: 28rpx;
  color: #333;
}

.history-date {
  font-size: 22rpx;
  color: #999;
  margin-top: 5rpx;
}

.history-score {
  font-size: 32rpx;
  color: #667eea;
  font-weight: bold;
}
