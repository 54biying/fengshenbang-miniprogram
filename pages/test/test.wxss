/* 测试页样式 */
.test-intro {
  text-align: center;
  padding: 60rpx 40rpx;
}

.test-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 48rpx;
}

.feature-list {
  text-align: left;
  margin-bottom: 60rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.feature-icon {
  color: #52c41a;
  font-size: 32rpx;
  margin-right: 16rpx;
}

.feature-text {
  font-size: 28rpx;
  color: #333;
}

.start-btn {
  width: 80%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 36rpx;
  border-radius: 48rpx;
}

.history-section {
  margin-top: 80rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
  text-align: left;
}

.history-list {
  text-align: left;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: white;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.history-info {
  display: flex;
  align-items: center;
}

.history-level {
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
  margin-right: 24rpx;
}

.history-date {
  font-size: 24rpx;
  color: #999;
}

.history-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #52c41a;
}

/* 测试中 */
.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #e8e8e8;
  border-radius: 4rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #36cfc9);
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  text-align: center;
  margin-bottom: 40rpx;
}

.question-card {
  background: white;
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.question-text {
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1.6;
  display: block;
  margin-bottom: 40rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  padding: 32rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.option-item.selected {
  border-color: #1890ff;
  background: #e6f7ff;
}

.option-label {
  width: 56rpx;
  height: 56rpx;
  background: #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: white;
  margin-right: 24rpx;
}

.option-item.selected .option-label {
  background: #1890ff;
}

.option-content {
  font-size: 30rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
}

.action-bar {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.action-bar .btn {
  flex: 1;
}

/* 测试结果 */
.test-result {
  padding: 40rpx;
}

.result-icon {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 32rpx;
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-icon.expert {
  background: linear-gradient(135deg, #f5222d, #faad14);
}

.level-badge {
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  text-align: center;
  margin-bottom: 16rpx;
}

.result-score {
  font-size: 36rpx;
  color: #1890ff;
  font-weight: bold;
  display: block;
  text-align: center;
  margin-bottom: 48rpx;
}

.result-analysis {
  background: white;
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.analysis-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 32rpx;
}

.analysis-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.analysis-name {
  width: 140rpx;
  font-size: 26rpx;
  color: #666;
}

.analysis-bar {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.analysis-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s;
}

.analysis-fill.low {
  background: #ff4d4f;
}

.analysis-fill.medium {
  background: #faad14;
}

.analysis-fill.high {
  background: #52c41a;
}

.analysis-score {
  width: 80rpx;
  font-size: 26rpx;
  color: #1890ff;
  text-align: right;
}

/* 学习建议 */
.suggestions-section {
  background: #fff7e6;
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.suggestions-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
  color: #d46b08;
}

.suggestion-item {
  display: flex;
  margin-bottom: 16rpx;
}

.suggestion-dot {
  color: #d46b08;
  margin-right: 12rpx;
  font-size: 28rpx;
}

.suggestion-text {
  font-size: 28rpx;
  color: #595959;
  flex: 1;
  line-height: 1.5;
}

/* 题目回顾 */
.review-section {
  background: white;
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.review-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
}

.review-item {
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
}

.review-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.review-question {
  display: flex;
  margin-bottom: 16rpx;
}

.review-num {
  font-weight: bold;
  color: #1890ff;
  margin-right: 12rpx;
}

.review-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
}

.review-answer {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.your-answer {
  font-size: 26rpx;
  font-weight: bold;
}

.your-answer.correct {
  color: #52c41a;
}

.your-answer.wrong {
  color: #ff4d4f;
}

.correct-answer {
  font-size: 26rpx;
  color: #52c41a;
}

.review-explanation {
  background: #f6ffed;
  padding: 20rpx;
  border-radius: 8rpx;
  border-left: 4rpx solid #52c41a;
}

.explanation-text {
  font-size: 26rpx;
  color: #389e0d;
  line-height: 1.6;
}

.result-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.result-actions .btn {
  flex: 1;
}
