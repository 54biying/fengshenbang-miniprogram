<!--pages/checkin/checkin.wxml-->
<view class="container">
  <!-- 头部统计 -->
  <view class="header">
    <view class="stat-item">
      <text class="stat-num">{{stats.totalCheckIns}}</text>
      <text class="stat-label">累计打卡</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.currentStreak}}</text>
      <text class="stat-label">连续天数</text>
    </view>
    <view class="stat-item highlight">
      <text class="stat-num">{{stats.points}}</text>
      <text class="stat-label">我的积分</text>
    </view>
  </view>

  <!-- 本周打卡日历 -->
  <view class="calendar-section">
    <view class="section-header">
      <text class="section-title">本周打卡</text>
      <text class="section-subtitle">坚持就是胜利！</text>
    </view>
    <view class="week-calendar">
      <view class="day-item {{item ? 'checked' : ''}}" wx:for="{{weekStatus}}" wx:key="index">
        <view class="day-circle">
          <text wx:if="{{item}}">✓</text>
          <text wx:else>·</text>
        </view>
        <text class="day-name">周{{['日','一','二','三','四','五','六'][index]}}</text>
      </view>
    </view>
  </view>

  <!-- 今日打卡区域 -->
  <view class="checkin-section" wx:if="{{!todayCheckedIn}}">
    <view class="section-header">
      <text class="section-title">今日打卡</text>
      <text class="expected-points">预计 +{{calculatePoints()}} 积分</text>
    </view>

    <!-- 学习内容分类 -->
    <view class="form-item">
      <text class="label">📚 学习内容</text>
      <view class="category-selector" bindtap="showCategorySelector">
        <view class="category-display" wx:if="{{selectedCategory}}">
          <text>{{categories.find(c => c.id === selectedCategory).icon}}</text>
          <text class="category-name">{{getSelectedCategoryName()}}</text>
        </view>
        <view class="category-placeholder" wx:else>
          <text>请选择学习内容分类</text>
          <text class="arrow">></text>
        </view>
      </view>
    </view>

    <!-- 学习任务 -->
    <view class="form-item">
      <text class="label">✅ 完成的任务 ({{selectedTasks.length}}项)</text>
      <view class="task-selector" bindtap="showTaskSelector">
        <view class="task-display" wx:if="{{selectedTasks.length > 0}}">
          <view class="task-tag" wx:for="{{getSelectedTaskNames()}}" wx:key="index">{{item}}</view>
        </view>
        <view class="task-placeholder" wx:else>
          <text>点击选择今日完成的学习任务</text>
          <text class="arrow">></text>
        </view>
      </view>
    </view>

    <!-- 学习时长 -->
    <view class="form-item">
      <text class="label">⏱️ 学习时长: {{studyTime}}分钟</text>
      <slider min="0" max="7" step="1" value="1" show-value="{{false}}" bindchange="onStudyTimeChange" block-size="20"/>
      <view class="time-labels">
        <text>15分</text>
        <text>60分</text>
        <text>180分</text>
      </view>
    </view>

    <!-- 心情选择 -->
    <view class="form-item">
      <text class="label">😊 今日心情</text>
      <view class="mood-selector">
        <view class="mood-item {{mood === 'happy' ? 'selected' : ''}}" data-mood="happy" bindtap="selectMood">
          <text class="mood-emoji">😊</text>
          <text class="mood-text">开心</text>
        </view>
        <view class="mood-item {{mood === 'normal' ? 'selected' : ''}}" data-mood="normal" bindtap="selectMood">
          <text class="mood-emoji">😐</text>
          <text class="mood-text">一般</text>
        </view>
        <view class="mood-item {{mood === 'tired' ? 'selected' : ''}}" data-mood="tired" bindtap="selectMood">
          <text class="mood-emoji">😴</text>
          <text class="mood-text">疲惫</text>
        </view>
        <view class="mood-item {{mood === 'excited' ? 'selected' : ''}}" data-mood="excited" bindtap="selectMood">
          <text class="mood-emoji">🤩</text>
          <text class="mood-text">兴奋</text>
        </view>
        <view class="mood-item {{mood === 'proud' ? 'selected' : ''}}" data-mood="proud" bindtap="selectMood">
          <text class="mood-emoji">😎</text>
          <text class="mood-text">自豪</text>
        </view>
      </view>
    </view>

    <!-- 学习笔记 -->
    <view class="form-item">
      <text class="label">📝 学习笔记（选填）</text>
      <textarea class="notes-input" placeholder="记录今天的学习内容、心得或遇到的问题..." value="{{notes}}" bindinput="onNotesInput" maxlength="200"/>
      <text class="char-count">{{notes.length}}/200</text>
    </view>

    <!-- 打卡按钮 -->
    <button class="checkin-btn {{!selectedCategory || selectedTasks.length === 0 ? 'disabled' : ''}}" bindtap="submitCheckin" disabled="{{!selectedCategory || selectedTasks.length === 0}}">
      立即打卡
    </button>
  </view>

  <!-- 已打卡状态 -->
  <view class="checked-section" wx:if="{{todayCheckedIn && todayData}}">
    <view class="success-header">
      <view class="success-icon">✓</view>
      <text class="success-text">今日已打卡</text>
      <text class="success-sub">坚持{{stats.currentStreak}}天，继续加油！</text>
    </view>
    
    <view class="today-summary">
      <view class="summary-item">
        <text class="summary-label">学习内容</text>
        <text class="summary-value">{{categories.find(c => c.id === todayData.category).name || todayData.category}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">学习时长</text>
        <text class="summary-value">{{todayData.studyTime}}分钟</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">完成任务</text>
        <text class="summary-value">{{todayData.tasks.length}}项</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">获得积分</text>
        <text class="summary-value highlight">+{{todayData.pointsEarned}}</text>
      </view>
    </view>
  </view>

  <!-- 打卡规则 -->
  <view class="rules-section">
    <text class="section-title">💎 积分规则</text>
    <view class="rule-list">
      <view class="rule-item">
        <text class="rule-icon">✓</text>
        <text class="rule-text">每日打卡 +10积分</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">✓</text>
        <text class="rule-text">学习30分钟 +10积分</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">✓</text>
        <text class="rule-text">学习60分钟 +20积分</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">✓</text>
        <text class="rule-text">连续3天 +20积分</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">✓</text>
        <text class="rule-text">连续7天 +50积分</text>
      </view>
    </view>
  </view>

  <!-- 任务选择弹窗 -->
  <view class="modal {{showTaskModal ? 'show' : ''}}" catchtouchmove="preventTouchMove">
    <view class="modal-mask" bindtap="closeTaskModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">选择完成的任务</text>
        <text class="modal-close" bindtap="closeTaskModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="task-list">
          <view class="task-option {{selectedTasks.includes(item.id) ? 'selected' : ''}}" wx:for="{{tasks}}" wx:key="id" data-id="{{item.id}}" bindtap="toggleTask">
            <text class="task-icon">{{item.icon}}</text>
            <view class="task-info">
              <text class="task-name">{{item.name}}</text>
              <text class="task-points">+{{item.points}}积分</text>
            </view>
            <view class="task-check {{selectedTasks.includes(item.id) ? 'checked' : ''}}">
              <text wx:if="{{selectedTasks.includes(item.id)}}">✓</text>
            </view>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-confirm" bindtap="closeTaskModal">确定 ({{selectedTasks.length}})</button>
      </view>
    </view>
  </view>

  <!-- 分类选择弹窗 -->
  <view class="modal {{showCategoryModal ? 'show' : ''}}" catchtouchmove="preventTouchMove">
    <view class="modal-mask" bindtap="closeCategoryModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">选择学习内容</text>
        <text class="modal-close" bindtap="closeCategoryModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="category-list">
          <view class="category-option {{selectedCategory === item.id ? 'selected' : ''}}" wx:for="{{categories}}" wx:key="id" data-id="{{item.id}}" bindtap="selectCategory">
            <text class="category-icon">{{item.icon}}</text>
            <text class="category-name">{{item.name}}</text>
            <view class="category-check {{selectedCategory === item.id ? 'checked' : ''}}">
              <text wx:if="{{selectedCategory === item.id}}">✓</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
