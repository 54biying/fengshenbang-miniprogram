<!--pages/checkin/checkin.wxml-->
<view class="container">
  <!-- 头部统计 -->
  <view class="header">
    <view class="stat-item">
      <text class="stat-num">{{stats.totalCheckIns || 0}}</text>
      <text class="stat-label">累计打卡</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.currentStreak || 0}}</text>
      <text class="stat-label">连续天数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{calculateTotalPoints()}}</text>
      <text class="stat-label">今日积分</text>
    </view>
  </view>

  <!-- 已打卡状态 -->
  <view class="checked-section" wx:if="{{todayCheckedIn}}">
    <view class="success-icon">✓</view>
    <text class="success-text">今日已完成打卡</text>
    <text class="success-sub">明天继续加油！</text>
  </view>

  <!-- 打卡表单 -->
  <view class="checkin-form" wx:if="{{!todayCheckedIn}}">
    
    <!-- 学习时长 -->
    <view class="form-section">
      <text class="section-title">⏱️ 学习时长</text>
      <view class="time-selector">
        <view class="time-display">
          <text class="time-num">{{studyTime}}</text>
          <text class="time-unit">分钟</text>
        </view>
        <slider min="15" max="180" step="15" value="{{studyTime}}" 
                show-value bindchange="onStudyTimeChange" 
                activeColor="#667eea" block-size="28"/>
        <view class="time-labels">
          <text>15分钟</text>
          <text>1小时</text>
          <text>3小时</text>
        </view>
      </view>
    </view>

    <!-- 学习内容分类 -->
    <view class="form-section">
      <text class="section-title">📚 学习内容分类</text>
      <view class="category-list">
        <view 
          class="category-item {{selectedCategory && selectedCategory.id === item.id ? 'selected' : ''}}" 
          wx:for="{{taskCategories}}" 
          wx:key="id"
          bindtap="selectCategory"
          data-id="{{item.id}}"
        >
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
      
      <!-- 显示选中分类的具体任务 -->
      <view class="task-detail-list" wx:if="{{selectedCategory}}">
        <text class="sub-title">{{selectedCategory.name}} - 选择具体任务</text>
        <view class="detail-tasks">
          <view 
            class="detail-task {{selectedTasks.findIndex(t => t.id === item.id) > -1 ? 'selected' : ''}}" 
            wx:for="{{selectedCategory.tasks}}" 
            wx:key="id"
            bindtap="toggleTask"
            data-id="{{item.id}}"
            data-points="{{item.points}}"
          >
            <text class="task-name">{{item.name}}</text>
            <text class="task-points">+{{item.points}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 常用任务 -->
    <view class="form-section">
      <text class="section-title">⭐ 常用打卡</text>
      <view class="common-tasks">
        <view 
          class="common-task {{selectedTasks.findIndex(t => t.id === item.id) > -1 ? 'selected' : ''}}" 
          wx:for="{{commonTasks}}" 
          wx:key="id"
          bindtap="toggleCommonTask"
          data-id="{{item.id}}"
          data-points="{{item.points}}"
        >
          <text class="task-icon">{{item.icon}}</text>
          <text class="task-name">{{item.name}}</text>
          <text class="task-points">+{{item.points}}</text>
        </view>
      </view>
    </view>

    <!-- 自定义任务 -->
    <view class="form-section">
      <text class="section-title">✏️ 自定义任务</text>
      <view class="custom-task-input">
        <input 
          class="custom-input" 
          placeholder="输入你的学习任务..." 
          value="{{newCustomTask}}"
          bindinput="onCustomTaskInput"
        />
        <button class="btn-add" bindtap="addCustomTask">添加</button>
      </view>
      
      <!-- 已添加的自定义任务 -->
      <view class="custom-tasks-list" wx:if="{{customTasks.length > 0}}">
        <view 
          class="custom-task-item {{selectedTasks.findIndex(t => t.id === item.id) > -1 ? 'selected' : ''}}" 
          wx:for="{{customTasks}}" 
          wx:key="id"
        >
          <view class="custom-task-left" bindtap="toggleCustomTask" data-id="{{item.id}}">
            <text class="custom-task-name">{{item.name}}</text>
            <text class="custom-task-points">+{{item.points}}</text>
          </view>
          <text class="btn-delete" bindtap="removeCustomTask" data-index="{{index}}">✕</text>
        </view>
      </view>
    </view>

    <!-- 心情选择 -->
    <view class="form-section">
      <text class="section-title">😊 今日心情</text>
      <view class="mood-selector">
        <view class="mood-item {{mood === 'happy' ? 'selected' : ''}}" data-mood="happy" bindtap="selectMood">
          <text class="mood-emoji">😊</text>
          <text class="mood-text">开心</text>
        </view>
        <view class="mood-item {{mood === 'normal' ? 'selected' : ''}}" data-mood="normal" bindtap="selectMood">
          <text class="mood-emoji">😐</text>
          <text class="mood-text">一般</text>
        </view>
        <view class="mood-item {{mood === 'tired' ? 'selected' : ''}}" data-mood="tired" bindtap="selectMood">
          <text class="mood-emoji">😴</text>
          <text class="mood-text">疲惫</text>
        </view>
        <view class="mood-item {{mood === 'excited' ? 'selected' : ''}}" data-mood="excited" bindtap="selectMood">
          <text class="mood-emoji">🤩</text>
          <text class="mood-text">兴奋</text>
        </view>
        <view class="mood-item {{mood === 'proud' ? 'selected' : ''}}" data-mood="proud" bindtap="selectMood">
          <text class="mood-emoji">😎</text>
          <text class="mood-text">自豪</text>
        </view>
      </view>
    </view>

    <!-- 学习笔记 -->
    <view class="form-section">
      <text class="section-title">📝 学习笔记（选填）</text>
      <textarea 
        class="notes-input" 
        placeholder="记录今天学到了什么..." 
        value="{{notes}}" 
        bindinput="onNotesInput" 
        maxlength="200"
      />
      <text class="char-count">{{notes.length || 0}}/200</text>
    </view>

    <!-- 打卡按钮 -->
    <view class="submit-section">
      <view class="points-preview" wx:if="{{selectedTasks.length > 0}}">
        <text class="preview-label">预计获得</text>
        <text class="preview-points">{{calculateTotalPoints()}} 积分</text>
      </view>
      <button class="btn-checkin {{selectedTasks.length === 0 ? 'disabled' : ''}}" bindtap="submitCheckin">
        {{selectedTasks.length === 0 ? '请选择学习任务' : '✓ 完成打卡'}}
      </button>
    </view>
  </view>
</view>
