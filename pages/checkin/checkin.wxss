/* pages/checkin/checkin.wxss */
.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 60rpx;
}

/* 头部统计 */
.header {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

/* 已打卡状态 */
.checked-section {
  background: #fff;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.success-icon {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  color: #fff;
  margin-bottom: 30rpx;
}

.success-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.success-sub {
  font-size: 28rpx;
  color: #999;
  margin-top: 15rpx;
}

/* 打卡表单 */
.checkin-form {
  padding: 30rpx;
}

.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  display: block;
}

.sub-title {
  font-size: 28rpx;
  color: #667eea;
  margin: 20rpx 0 15rpx;
  display: block;
}

/* 学习时长 */
.time-selector {
  padding: 10rpx 0;
}

.time-display {
  text-align: center;
  margin-bottom: 20rpx;
}

.time-num {
  font-size: 64rpx;
  font-weight: bold;
  color: #667eea;
}

.time-unit {
  font-size: 28rpx;
  color: #666;
  margin-left: 10rpx;
}

.time-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 内容分类 */
.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.category-item {
  width: calc(33.333% - 10rpx);
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 25rpx 10rpx;
  text-align: center;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.category-item.selected {
  background: #e8f4ff;
  border-color: #667eea;
}

.category-icon {
  font-size: 44rpx;
  display: block;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333;
}

/* 具体任务 */
.task-detail-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.detail-tasks {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.detail-task {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-width: 200rpx;
  border: 2rpx solid transparent;
}

.detail-task.selected {
  background: #e8f4ff;
  border-color: #667eea;
}

.detail-task .task-name {
  font-size: 26rpx;
  color: #333;
}

.detail-task .task-points {
  font-size: 22rpx;
  color: #667eea;
  font-weight: bold;
  margin-left: 15rpx;
}

/* 常用任务 */
.common-tasks {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.common-task {
  width: calc(25% - 15rpx);
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 25rpx 10rpx;
  text-align: center;
  border: 3rpx solid transparent;
}

.common-task.selected {
  background: #e8f4ff;
  border-color: #667eea;
}

.common-task .task-icon {
  font-size: 44rpx;
  display: block;
  margin-bottom: 10rpx;
}

.common-task .task-name {
  font-size: 22rpx;
  color: #333;
  display: block;
}

.common-task .task-points {
  font-size: 20rpx;
  color: #667eea;
  margin-top: 5rpx;
  display: block;
}

/* 自定义任务 */
.custom-task-input {
  display: flex;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.custom-input {
  flex: 1;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 25rpx;
  font-size: 28rpx;
}

.btn-add {
  width: 120rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-tasks-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.custom-task-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 25rpx;
  border: 2rpx solid transparent;
}

.custom-task-item.selected {
  background: #e8f4ff;
  border-color: #667eea;
}

.custom-task-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.custom-task-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.custom-task-points {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
  margin-left: 15rpx;
}

.btn-delete {
  width: 50rpx;
  height: 50rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-left: 15rpx;
}

/* 心情选择 */
.mood-selector {
  display: flex;
  justify-content: space-around;
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 15rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
  border: 3rpx solid transparent;
  min-width: 100rpx;
}

.mood-item.selected {
  background: #fff3e0;
  border-color: #ff9800;
}

.mood-emoji {
  font-size: 52rpx;
}

.mood-text {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 学习笔记 */
.notes-input {
  width: 100%;
  height: 180rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.char-count {
  font-size: 22rpx;
  color: #999;
  text-align: right;
  margin-top: 10rpx;
  display: block;
}

/* 提交区域 */
.submit-section {
  margin-top: 40rpx;
}

.points-preview {
  text-align: center;
  margin-bottom: 20rpx;
}

.preview-label {
  font-size: 26rpx;
  color: #666;
  display: block;
}

.preview-points {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
  margin-top: 10rpx;
}

.btn-checkin {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-checkin.disabled {
  background: #ccc;
}
