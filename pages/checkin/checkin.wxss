/* pages/checkin/checkin.wxss */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #f0f7ff 0%, #f5f5f5 100%);
  min-height: 100vh;
}

/* 头部统计 */
.header {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  padding: 40rpx 20rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.3);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 52rpx;
  font-weight: bold;
  color: white;
}

.stat-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
}

.stat-item.highlight .stat-num {
  color: #fff566;
}

/* 区域通用样式 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.section-subtitle {
  font-size: 26rpx;
  color: #999;
}

.expected-points {
  font-size: 28rpx;
  color: #f5222d;
  font-weight: bold;
  background: #fff1f0;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 日历区域 */
.calendar-section {
  background: white;
  padding: 32rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.week-calendar {
  display: flex;
  justify-content: space-around;
}

.day-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.day-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  font-size: 36rpx;
  color: #bfbfbf;
  transition: all 0.3s;
}

.day-item.checked .day-circle {
  background: linear-gradient(135deg, #52c41a, #95de64);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.4);
}

.day-name {
  font-size: 24rpx;
  color: #999;
}

.day-item.checked .day-name {
  color: #52c41a;
  font-weight: bold;
}

/* 打卡表单 */
.checkin-section {
  background: white;
  padding: 32rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 36rpx;
}

.label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
  display: block;
}

/* 分类选择 */
.category-selector, .task-selector {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 28rpx;
}

.category-display, .task-display {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-placeholder, .task-placeholder {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #999;
  font-size: 28rpx;
}

.category-name {
  font-size: 30rpx;
  color: #333;
  margin-left: 16rpx;
}

.task-tag {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  color: white;
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
}

.arrow {
  color: #999;
  font-size: 32rpx;
}

/* 滑块 */
.time-labels {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 心情选择 */
.mood-selector {
  display: flex;
  justify-content: space-between;
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}

.mood-item.selected {
  background: linear-gradient(135deg, #fff7e6, #fff1b8);
  border: 2rpx solid #faad14;
}

.mood-emoji {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.mood-text {
  font-size: 24rpx;
  color: #666;
}

.mood-item.selected .mood-text {
  color: #d46b08;
  font-weight: bold;
}

/* 笔记输入 */
.notes-input {
  width: 100%;
  height: 180rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

/* 打卡按钮 */
.checkin-btn {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  color: white;
  border-radius: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: bold;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.4);
}

.checkin-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
}

/* 已打卡状态 */
.checked-section {
  background: white;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.success-header {
  background: linear-gradient(135deg, #52c41a, #95de64);
  padding: 48rpx;
  text-align: center;
}

.success-icon {
  width: 100rpx;
  height: 100rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #52c41a;
  margin: 0 auto 20rpx;
}

.success-text {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  display: block;
}

.success-sub {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 12rpx;
  display: block;
}

.today-summary {
  padding: 32rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.summary-item:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
}

.summary-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.summary-value.highlight {
  color: #f5222d;
  font-weight: bold;
}

/* 规则区域 */
.rules-section {
  background: linear-gradient(135deg, #fffbe6, #fff1b8);
  padding: 32rpx;
  border-radius: 20rpx;
  border: 2rpx solid #ffe58f;
}

.rules-section .section-title {
  color: #d46b08;
}

.rule-list {
  margin-top: 20rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.rule-icon {
  color: #52c41a;
  margin-right: 16rpx;
  font-size: 28rpx;
}

.rule-text {
  font-size: 28rpx;
  color: #595959;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
}

.modal.show {
  visibility: visible;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body {
  max-height: 60vh;
  overflow-y: auto;
  padding: 20rpx 32rpx;
}

.modal-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-confirm {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  color: white;
  border-radius: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

/* 任务列表 */
.task-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}

.task-option.selected {
  background: #e6f7ff;
  border: 2rpx solid #1890ff;
}

.task-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.task-info {
  flex: 1;
}

.task-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.task-points {
  font-size: 24rpx;
  color: #f5222d;
  margin-top: 4rpx;
  display: block;
}

.task-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-check.checked {
  background: #1890ff;
  border-color: #1890ff;
  color: white;
}

/* 分类列表 */
.category-option {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}

.category-option.selected {
  background: #e6f7ff;
  border: 2rpx solid #1890ff;
}

.category-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.category-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.category-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-check.checked {
  background: #1890ff;
  border-color: #1890ff;
  color: white;
}
