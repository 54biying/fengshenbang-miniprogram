/* pages/checkin/checkin.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 头部统计 */
.header {
  display: flex;
  justify-content: space-around;
  background: #fff;
  padding: 40rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 日历区域 */
.calendar-section {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}

.week-calendar {
  display: flex;
  justify-content: space-around;
}

.day-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.day-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  font-size: 36rpx;
  color: #fff;
}

.day-circle.checked {
  background: #52c41a;
}

.day-name {
  font-size: 24rpx;
  color: #666;
}

/* 打卡表单 */
.checkin-section {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 心情选择 */
.mood-selector {
  display: flex;
  justify-content: space-around;
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.mood-item.selected {
  background: #e6f7ff;
  border: 2rpx solid #1890ff;
}

.mood-emoji {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.mood-text {
  font-size: 24rpx;
  color: #666;
}

/* 笔记输入 */
.notes-input {
  width: 100%;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

/* 打卡按钮 */
.checkin-btn {
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

/* 已打卡状态 */
.checked-section {
  background: #fff;
  padding: 60rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  background: #52c41a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
  margin: 0 auto 20rpx;
}

.success-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #52c41a;
  display: block;
}

.success-sub {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

/* 规则区域 */
.rules-section {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.rule-dot {
  color: #1890ff;
  margin-right: 10rpx;
}

.rule-text {
  font-size: 28rpx;
  color: #666;
}
