<!-- 首页 - 简化版 -->
<view class="container">
  <!-- 顶部用户信息 -->
  <view class="header">
    <view class="user-info" bindtap="goToProfile">
      <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" />
      <view class="user-meta">
        <text class="user-name">{{userInfo.name || '访客'}}</text>
        <text class="user-level" wx:if="{{userInfo}}">Lv.{{userLevel || 0}} 学习者</text>
        <text class="user-level" wx:else>点击登录</text>
      </view>
    </view>
    <view class="points-box" bindtap="goToPoints" wx:if="{{userInfo}}">
      <text class="points-num">{{userPoints || 0}}</text>
      <text class="points-label">积分</text>
    </view>
  </view>

  <!-- 今日打卡快捷入口 -->
  <view class="quick-checkin" bindtap="goToCheckin" wx:if="{{userInfo}}">
    <view class="checkin-left">
      <text class="checkin-title">📅 今日打卡</text>
      <text class="checkin-status {{todayCheckedIn ? 'done' : ''}}">
        {{todayCheckedIn ? '已完成 ✓' : '还未打卡'}}
      </text>
    </view>
    <view class="checkin-right">
      <view class="streak-info">
        <text class="streak-num">{{checkinStats.currentStreak || 0}}</text>
        <text class="streak-label">连续天数</text>
      </view>
    </view>
  </view>

  <!-- 核心功能入口 -->
  <view class="main-features">
    <view class="feature-row">
      <view class="feature-big" bindtap="goToTest">
        <text class="feature-icon-big">📝</text>
        <text class="feature-name-big">AI能力测试</text>
        <text class="feature-desc-big">10题测出真实水平</text>
      </view>
      <view class="feature-big" bindtap="goToMatch">
        <text class="feature-icon-big">🤝</text>
        <text class="feature-name-big">找学习伙伴</text>
        <text class="feature-desc-big">匹配同水平同学</text>
      </view>
    </view>
    <view class="feature-row">
      <view class="feature-big" bindtap="goToCheckin">
        <text class="feature-icon-big">📅</text>
        <text class="feature-name-big">每日打卡</text>
        <text class="feature-desc-big">记录学习轨迹</text>
      </view>
      <view class="feature-big" bindtap="goToMentor">
        <text class="feature-icon-big">🎓</text>
        <text class="feature-name-big">拜师学艺</text>
        <text class="feature-desc-big">向高手请教</text>
      </view>
    </view>
  </view>

  <!-- 未登录提示 -->
  <view class="login-tip" wx:if="{{!userInfo}}">
    <text class="tip-text">登录后解锁全部功能</text>
    <button class="btn-login" bindtap="goToLogin">立即登录</button>
  </view>

  <!-- 学习数据概览 -->
  <view class="stats-section" wx:if="{{userInfo}}">
    <text class="section-title">学习数据</text>
    <view class="stats-grid">
      <view class="stat-box">
        <text class="stat-num">{{stats.testCount || 0}}</text>
        <text class="stat-label">测试次数</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{stats.matchCount || 0}}</text>
        <text class="stat-label">匹配伙伴</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{checkinStats.totalCheckIns || 0}}</text>
        <text class="stat-label">累计打卡</text>
      </view>
    </view>
  </view>
</view>
