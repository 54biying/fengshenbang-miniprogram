/* pages/index/index.wxss - 简化版 */
.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 40rpx;
}

/* 顶部用户信息 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.user-meta {
  margin-left: 20rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.user-level {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.points-box {
  background: rgba(255,255,255,0.2);
  padding: 20rpx 30rpx;
  border-radius: 16rpx;
  text-align: center;
}

.points-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.points-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

/* 今日打卡快捷入口 */
.quick-checkin {
  margin: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.checkin-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.checkin-status {
  font-size: 26rpx;
  color: #ff9800;
  margin-top: 10rpx;
  display: block;
}

.checkin-status.done {
  color: #52c41a;
}

.streak-info {
  text-align: center;
}

.streak-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
}

.streak-label {
  font-size: 22rpx;
  color: #999;
}

/* 核心功能入口 */
.main-features {
  margin: 0 30rpx;
}

.feature-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.feature-big {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.feature-icon-big {
  font-size: 60rpx;
  display: block;
  margin-bottom: 15rpx;
}

.feature-name-big {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.feature-desc-big {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 未登录提示 */
.login-tip {
  margin: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.tip-text {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}

.btn-login {
  width: 300rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: none;
}

/* 学习数据概览 */
.stats-section {
  margin: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-box {
  text-align: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}
